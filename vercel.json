{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/search", "dest": "/api/search.js" },
    { "src": "/inventory", "dest": "/api/inventory.js" },
    { "src": "/inquiry", "dest": "/api/inquiry.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
